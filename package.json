    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.1",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "bullmq": "^5.3.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
