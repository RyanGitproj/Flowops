# Node Environment
NODE_ENV=production
PORT=3000

# Database (Docker Compose)
DATABASE_URL=postgresql://flowops:flowops@postgres:5432/flowops?schema=public

# Redis (Docker Compose)
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
